# База API, к которой ходит мини-приложение. Пустая строка = same-origin (когда
# бэк и фронт на одном домене). Для Cloudflare Pages + отдельного Railway бэкенда
# укажи полный URL.
VITE_API_BASE_URL=

# Для локального `npm run dev`: адрес, куда проксировать /api.
# Используется только vite.config.ts.
VITE_API_PROXY=http://127.0.0.1:8080
