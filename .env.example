BOT_TOKEN=your_telegram_bot_token
TEXT_PROVIDER=gigachat
TEXT_MODEL=GigaChat-2-Pro
GIGACHAT_CLIENT_ID=your_gigachat_client_id
GIGACHAT_AUTHORIZATION_KEY=your_base64_client_id_colon_secret
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_VERIFY_SSL=true
# Cloudflare is optional now — image generation is disabled in the Mini App flow.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
SQLITE_PATH=bot.db
MAX_INPUT_LENGTH=120
DAILY_TEXT_LIMIT=20
DAILY_IMAGE_LIMIT=5
# URL, where Mini App (frontend) is served. Must be HTTPS in production.
MINIAPP_URL=https://miniapp.example.com
# API (FastAPI) host/port. 0.0.0.0 + PORT suits Railway.
API_HOST=0.0.0.0
API_PORT=8080
# Comma-separated allowed origins for Mini App CORS, e.g. https://miniapp.example.com
API_CORS_ORIGINS=
# For local dev ONLY: allow unauthenticated requests with X-Debug-User:1 header
DEBUG_USER_ID=0
